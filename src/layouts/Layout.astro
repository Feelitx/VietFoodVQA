<!doctype html>
<html lang="vi" class="dark antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <meta name="description" content="Vietnamese Food VQA - Annotation & Verify Tool" />
    <title>VietFoodVQA</title>
    <style is:global>
      @tailwind base;
      @tailwind components;
      @tailwind utilities;

      @layer base {
        html { @apply text-slate-200 bg-slate-950 selection:bg-indigo-500/30; }
        body { @apply font-sans h-screen overflow-hidden flex flex-col md:flex-row bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,119,198,0.2),rgba(255,255,255,0))]; }
      }

      @layer components {
        /* App shell layout */
        .app { @apply flex w-full h-screen; }
        .sidebar { @apply w-72 shrink-0 bg-slate-900/60 backdrop-blur-xl border-r border-white/5 flex flex-col h-full overflow-hidden; }
        .sidebar-logo { @apply p-6 border-b border-white/5; }
        .sidebar-logo > div { @apply text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 to-purple-400 tracking-tight; }
        .sidebar-logo span { @apply block mt-1 text-xs font-medium text-slate-500; }
        
        /* Navigation Links */
        .nav { @apply p-4 space-y-1; }
        .nav a { @apply flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 font-medium text-sm transition-all duration-300; }
        .nav a:hover { @apply bg-white/5 text-slate-100; }
        .nav a.active { @apply bg-indigo-500/10 text-indigo-400 shadow-[inset_0_0_0_1px_rgba(99,102,241,0.2)]; }
        .nav-divider { @apply h-px bg-gradient-to-r from-transparent via-white/10 to-transparent my-4; }
        
        .sidebar-controls { @apply flex-1 overflow-y-auto p-4 space-y-4 custom-scrollbar; }
        
        /* Main Content */
        .main { @apply flex-1 h-full overflow-y-auto custom-scrollbar relative bg-transparent; }
        .main-inner { @apply p-6 md:p-10 max-w-7xl mx-auto; }
        .page-title { @apply text-3xl font-bold text-white mb-8 tracking-tight; }
        
        /* Legacy Cards -> Modern Glassmorphism */
        .card { @apply bg-slate-900/40 backdrop-blur-md border border-white/5 rounded-2xl p-6 shadow-xl mb-5 space-y-4 transition-all hover:bg-slate-900/50 hover:border-white/10; }
        .card-title { @apply text-xs font-bold text-slate-400 uppercase tracking-widest flex items-center gap-2; }
        
        /* Forms */
        label { @apply block text-sm font-medium text-slate-300 mb-1.5; }
        input[type="text"], input[type="number"], select, textarea {
          @apply w-full bg-slate-950/50 border border-white/10 text-white rounded-xl px-4 py-2.5 text-sm transition-all focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500/50 shadow-inner;
        }
        select option { @apply bg-slate-900 text-white; }
        .form-group { @apply mb-4; }
        
        /* Buttons */
        .btn { @apply inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl font-semibold text-sm transition-all duration-300 active:scale-95 disabled:opacity-50 disabled:pointer-events-none; }
        .btn-primary { @apply bg-indigo-600 hover:bg-indigo-500 text-white shadow-lg shadow-indigo-500/25 border border-indigo-500/50; }
        .btn-secondary { @apply bg-white/5 hover:bg-white/10 text-slate-200 border border-white/10 backdrop-blur-sm; }
        .btn-full { @apply w-full; }
        
        /* Metrics */
        .metrics { @apply flex flex-wrap gap-4 mb-6; }
        .metric { @apply flex-1 min-w-[120px] bg-slate-900/40 backdrop-blur-md border border-white/5 rounded-2xl p-5 hover:border-white/10 transition-all; }
        .metric-label { @apply text-xs font-semibold text-slate-400 uppercase tracking-wider; }
        .metric-value { @apply text-3xl font-bold text-white mt-1; }
        
        /* Progress */
        .progress-wrap { @apply h-2 w-full bg-white/5 rounded-full overflow-hidden my-3 shadow-inner; }
        .progress-bar { @apply h-full bg-gradient-to-r from-indigo-500 to-purple-500 rounded-full transition-all duration-700 ease-out; }
        
        /* Badges */
        .badge { @apply inline-flex px-2.5 py-0.5 rounded-full text-xs font-bold tracking-wide border; }
        .badge-green { @apply bg-emerald-500/10 text-emerald-400 border-emerald-500/20; }
        .badge-red { @apply bg-rose-500/10 text-rose-400 border-rose-500/20; }
        .badge-yellow { @apply bg-amber-500/10 text-amber-400 border-amber-500/20; }
        .badge-blue { @apply bg-indigo-500/10 text-indigo-400 border-indigo-500/20; }
        .badge-gray { @apply bg-slate-500/10 text-slate-400 border-slate-500/20; }

        /* Alerts */
        .alert { @apply p-4 rounded-xl text-sm font-medium mb-4 flex items-center gap-3 backdrop-blur-sm border; }
        .alert-error { @apply bg-rose-500/10 text-rose-300 border-rose-500/30; }
        .alert-success { @apply bg-emerald-500/10 text-emerald-300 border-emerald-500/30; }
        .alert-info { @apply bg-indigo-500/10 text-indigo-300 border-indigo-500/30; }
        .alert-warning { @apply bg-amber-500/10 text-amber-300 border-amber-500/30; }
        
        /* Grid & Tabs */
        .cols2 { @apply grid grid-cols-1 lg:grid-cols-2 gap-6; }
        .cols3 { @apply grid grid-cols-1 md:grid-cols-3 gap-4; }
        
        .tabs { @apply flex gap-2 border-b border-white/10 mb-6 px-1; }
        .tab-btn { @apply px-5 py-3 rounded-t-xl text-sm font-semibold text-slate-400 transition-all border-b-2 border-transparent hover:text-slate-200; }
        .tab-btn.active { @apply text-indigo-400 border-indigo-500 bg-white/5; }
        .tab-panel { @apply hidden; }
        .tab-panel.active { display: block; animation: tabFade 0.3s ease-out forwards; }
        @keyframes tabFade {
          from { opacity: 0; transform: translateY(5px); }
          to { opacity: 1; transform: translateY(0); }
        }

        /* Radio Group */
        .radio-group { @apply flex flex-wrap gap-2; }
        .radio-opt { @apply flex items-center gap-2 px-4 py-2.5 rounded-xl border border-white/10 bg-slate-900/40 text-sm font-medium text-slate-300 cursor-pointer transition-all hover:bg-slate-900/60 hover:border-white/20; }
        .radio-opt input { @apply hidden; }
        .radio-opt.checked { @apply bg-indigo-500/10 border-indigo-500/50 text-indigo-300 shadow-[inset_0_0_0_1px_rgba(99,102,241,0.2)]; }
        
        /* Images and Cards */
        .img-preview { @apply w-full rounded-2xl object-cover max-h-[500px] border border-white/10 shadow-2xl; }
        .triple-card { @apply bg-slate-900/30 border border-white/5 rounded-xl p-4 mb-3 transition-all hover:border-indigo-400/30 hover:bg-slate-900/50 hover:shadow-lg hover:shadow-indigo-500/5; }
        .triple-text { @apply font-semibold text-sm text-slate-200 mb-2; }
        
        /* Custom Scrollbar */
        .custom-scrollbar::-webkit-scrollbar { @apply w-2; }
        .custom-scrollbar::-webkit-scrollbar-track { @apply bg-transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { @apply bg-white/10 rounded-full hover:bg-white/20 transition-all; }
        
        /* Typography utils */
        .muted { @apply text-slate-400 text-sm; }
        .breadcrumb { @apply flex items-center gap-2 flex-wrap text-sm text-slate-400 mb-6 bg-slate-900/40 px-4 py-2.5 rounded-xl border border-white/5 backdrop-blur-md w-fit; }
        .breadcrumb b { @apply text-slate-200; }
        .nav-divider { @apply h-px bg-white/5 my-4; }
        .nav-pos { @apply text-xs font-semibold text-indigo-400 mt-2 text-right; }

        hr { @apply border-t border-white/10 my-8; }

        /* Spinner Component */
        .loading-center { @apply flex justify-center py-20; }
        .spinner { @apply w-10 h-10 rounded-full border-[3px] border-white/10 border-t-indigo-500 animate-spin; }
      }
    </style>
  </head>
  <body>
    <div class="app">
      <nav class="sidebar">
        <div class="sidebar-logo">
          <div>🍜 VietFoodVQA</div>
          <span>Annotation & Verify Tool</span>
        </div>
        <div class="nav">
          <a href="/verify-images" id="nav-images">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
            Verify Images
          </a>
          <a href="/verify-vqa" id="nav-vqa">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
            Verify VQA
          </a>
          <a href="/verify-triples" id="nav-triples">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
            Verify KG Triples
          </a>
        </div>
        <div class="sidebar-controls" id="sidebar-controls">
          <!-- Page-specific controls injected here by JS -->
        </div>
      </nav>
      <main class="main custom-scrollbar">
        <div class="main-inner">
          <slot />
        </div>
      </main>
    </div>
    <script>
      const path = location.pathname;
      document.querySelectorAll('.nav a').forEach(a => {
        if (a.getAttribute('href') === path) a.classList.add('active');
      });
    </script>
  </body>
</html>
